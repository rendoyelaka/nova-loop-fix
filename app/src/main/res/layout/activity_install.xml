<?xml version="1.0" encoding="utf-8"?>
<!--
    Play Store-style install screen.
    Dots are animated programmatically in InstallActivity.kt
    IDs used by InstallActivity.kt: progress_bar_install, tv_status, dots_container
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Dots container — filled & animated by InstallActivity at runtime -->
    <FrameLayout
        android:id="@+id/dots_container"
        android:layout_width="160dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true"
        android:layout_marginBottom="60dp" />

    <!-- Bottom section: status + progress + size + Google Play branding -->
    <LinearLayout
        android:id="@+id/bottom_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <!-- Status + progress + size -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="4dp">

            <!-- Status text: Installing… / Please wait… / Finishing up… -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Installing…"
                android:textColor="#757575"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="6dp" />

            <!-- Indeterminate progress bar — thin 2dp like Play Store -->
            <ProgressBar
                android:id="@+id/progress_bar_install"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:indeterminate="true"
                android:indeterminateTint="#4285F4"
                android:progressTint="#4285F4" />

            <!-- APK size label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 MB"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                android:fontFamily="sans-serif"
                android:layout_marginTop="5dp" />

        </LinearLayout>

        <!-- Google Play branding: logo + text centered -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="18dp"
            android:paddingBottom="24dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_google_play"
                android:contentDescription="@null"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Google Play"
                android:textColor="#202124"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
